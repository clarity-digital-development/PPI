# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key-here

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (Email)
RESEND_API_KEY=re_...

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=https://pinkpostinstallations.com

# Admin Email (for notifications)
ADMIN_EMAIL=contact@pinkposts.com

# Google Maps Places API key — enables address autocomplete on the order form.
# Without this the address fields fall back to plain text entry.
# Restrict the key in Google Cloud Console to: HTTP referrers (your domains)
# + Maps JavaScript API + Places API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
