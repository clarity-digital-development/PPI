# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key-here

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (Email)
RESEND_API_KEY=re_...

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=https://pinkpostinstallations.com

# Admin Email (for notifications)
ADMIN_EMAIL=contact@pinkposts.com

# Cron Bearer Secret — required by every /api/cron/* endpoint. The post-rental
# and inventory-hold-sweeper routes return 503 when unset (fail-closed). Hand
# this to whichever scheduler hits the endpoints (Railway Cron Service, etc.).
CRON_SECRET=

# Post-rental billing rollout switch (ISO date string).
# Orders whose installation pre-dates this date are GRANDFATHERED — the daily
# cron will never schedule a charge for them unless an admin flips the
# per-order `postRentalEnabledOverride` toggle. Default below keeps the cron
# DORMANT. Set to a real rollout date (e.g. "2026-07-01T00:00:00Z") to go live.
POST_RENTAL_BILLING_START_AT=2099-01-01T00:00:00Z

# Google Maps Places API key — enables address autocomplete on the order form.
# Without this the address fields fall back to plain text entry.
# Restrict the key in Google Cloud Console to: HTTP referrers (your domains)
# + Maps JavaScript API + Places API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Routes API key — used SERVER-SIDE ONLY by lib/service-area to fetch
# precise drive times for borderline ZIPs (Berea-style back-road properties
# where the haversine estimate underpredicts and silently misses a surcharge).
# Without this the resolver falls back to the haversine estimate (current
# behavior — safe but undercharges on the back-road edge cases).
# Restrict the key in Google Cloud Console to: IP addresses (your server IPs)
# + Routes API. Set a $20/mo billing alert as a backstop. The cache is sized
# to stay well inside the 10K/mo free tier at PPI's volume.
GOOGLE_MAPS_SERVER_API_KEY=
