// Prisma Schema for Pink Post Installations
// PostgreSQL on Railway

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// NextAuth.js Models
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

// ============================================
// User Model (combines NextAuth User + Profile)
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  password      String? // Hashed password for credentials auth
  name          String?
  image         String?

  // Profile fields
  fullName            String?  @map("full_name")
  phone               String?
  company             String?
  role                UserRole @default(customer)
  stripeCustomerId    String?  @map("stripe_customer_id")
  // Per-customer exemption from service-area gating (out-of-area block + surcharge).
  // Admin-toggleable for relationship customers; team_admin role is always exempt.
  isServiceAreaExempt Boolean  @default(false) @map("is_service_area_exempt")
  // Admin-toggle that switches a customer's checkout from "Pay now" to
  // "Add to invoice". Their orders skip Stripe at placement and accumulate
  // until an admin bundles them into an Invoice for collection.
  invoiceBilling      Boolean  @default(false) @map("invoice_billing")
  // CR2 (Round 22): admin-toggle that bills this account a single flat fee per
  // order ($66.07 = $60 base + $2.47 fuel + 6% tax) regardless of items chosen.
  // Enforced server-side at order create/edit; items still flow to fulfillment.
  flatFeeBilling      Boolean  @default(false) @map("flat_fee_billing")
  // Optional billing-contact email — when set, bundled-invoice emails go
  // here instead of the broker's account email. Lets a broker route bills
  // to their accountant without forwarding. Falls back to `email` when null.
  billingEmail        String?  @map("billing_email")

  // Team membership (for RE teams managed by a team_admin who places orders
  // on behalf of their agents). Both team_admins and agents have a teamId.
  teamId String? @map("team_id")

  // Notification preferences — defaults preserve current send-everything behavior except marketing
  emailOrderConfirmations    Boolean   @default(true) @map("email_order_confirmations")
  emailServiceRequests       Boolean   @default(true) @map("email_service_requests")
  emailMarketing             Boolean   @default(false) @map("email_marketing")
  notificationPrefsUpdatedAt DateTime? @map("notification_prefs_updated_at")

  // Policy-notice acceptance — modal shown to non-exempt users on next dashboard
  // load when policyNoticeVersion < CURRENT_NOTICE_VERSION (see lib/policy-notices.ts).
  // Defaults make every existing user re-see v1 once; team_admin/admin are exempt.
  policyNoticeAcceptedAt DateTime? @map("policy_notice_accepted_at")
  policyNoticeVersion    Int       @default(0) @map("policy_notice_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Business relations
  orders                Order[]
  invoices              Invoice[]
  installations         Installation[]
  customerSigns         CustomerSign[]
  customerRiders        CustomerRider[]
  customerLockboxes     CustomerLockbox[]
  customerBrochureBoxes CustomerBrochureBox[]
  customerOtherItems    CustomerOtherItem[]
  paymentMethods        PaymentMethod[]
  serviceRequests       ServiceRequest[]
  notifications         Notification[]
  promoCodeUsages       PromoCodeUsage[]

  team                      Team?                  @relation(fields: [teamId], references: [id])
  // If this user is the login for a managed team member (hybrid upgrade), this
  // is their TeamMember record.
  teamMember                TeamMember?            @relation("TeamMemberUser")
  // Orders placed by THIS user on behalf of an agent. The Order's userId is
  // the agent; placedByUserId is the team_admin who actually placed it.
  ordersPlacedFor           Order[]                @relation("OrdersPlacedBy")
  ordersCancelled           Order[]                @relation("OrderCancelledBy")
  auditLogs                 AuditLog[]             @relation("AuditActor")
  preferenceChanges         UserPreferenceChange[]
  heldInventoryAsOwner      InventoryHold[]        @relation("InventoryHoldOwner")
  heldInventoryAsActor      InventoryHold[]        @relation("InventoryHoldActor")
  heldInventoryOnBehalfOfMe InventoryHold[]        @relation("InventoryHoldOnBehalfOf")

  @@index([teamId])
  @@map("users")
}

enum UserRole {
  customer
  admin
  team_admin
}

// A team of real-estate agents managed by one or more team_admin users.
// The team_admin places orders on behalf of agents and pays from their own
// card; the order itself is recorded under the agent's account.
model Team {
  id                 String   @id @default(cuid())
  name               String // e.g. "Peggy Heckert Team"
  // Per-broker perk: when true, installing an OWNED lockbox (sentri/supra,
  // mechanical-owned, or at-property) is free for this team. Renting one is
  // still charged normally.
  freeLockboxInstall Boolean  @default(false) @map("free_lockbox_install")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // team_admin (and any agents that have their own login) share teamId via the
  // User.teamId relation.
  members     User[]
  // The managed roster — agents as name-only records, optionally upgraded to a
  // linked User login (hybrid model).
  teamMembers TeamMember[]

  @@map("teams")
}

// A managed agent on a team. Starts as a name-only record; can later be
// "upgraded" to a full login by linking a User (hybrid model). Inventory and
// orders reference the member, so assignments survive even before/after the
// agent has their own login. Soft-removed (removedAt) rather than deleted so
// their assigned inventory/order history is preserved.
model TeamMember {
  id        String    @id @default(cuid())
  teamId    String    @map("team_id")
  name      String
  email     String?
  phone     String?
  // Linked login account once upgraded from name-only. Null = name-only.
  userId    String?   @unique @map("user_id")
  removedAt DateTime? @map("removed_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  team Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User? @relation("TeamMemberUser", fields: [userId], references: [id])

  @@index([teamId])
  @@map("team_members")
}

// ============================================
// Notifications
// ============================================

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  link      String? // Optional link to relevant page
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  order_confirmed
  order_scheduled
  order_in_progress
  order_completed
  order_cancelled
  service_request_acknowledged
  service_request_scheduled
  service_request_completed
  removal_reminder
  welcome
}

// ============================================
// Product Catalog
// ============================================

model PostType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  orders Order[]

  @@map("post_types")
}

model RiderCatalog {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  rentalPrice Decimal  @map("rental_price") @db.Decimal(10, 2)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  customerRiders     CustomerRider[]
  installationRiders InstallationRider[]
  orderItems         OrderItem[]

  @@map("rider_catalog")
}

model LockboxType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  rentalPrice Decimal? @map("rental_price") @db.Decimal(10, 2)
  installFee  Decimal  @map("install_fee") @db.Decimal(10, 2)
  isRentable  Boolean  @default(false) @map("is_rentable")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  customerLockboxes     CustomerLockbox[]
  installationLockboxes InstallationLockbox[]

  @@map("lockbox_types")
}

// ============================================
// Customer Inventory
// ============================================

model CustomerSign {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  description        String
  imageUrl           String?   @map("image_url")
  inStorage          Boolean   @default(true) @map("in_storage")
  // Team feature: when a team_admin assigns this item to one of their agents,
  // this points at the TeamMember it belongs to (null = unassigned / pool).
  assignedToMemberId String?   @map("assigned_to_member_id")
  // Soft-hold: when this item is reserved in someone's cart, heldByHoldId
  // points at the InventoryHold row. heldUntil is a denormalized copy of
  // InventoryHold.expiresAt — both columns must be kept in sync.
  heldByHoldId       String?   @map("held_by_hold_id")
  heldUntil          DateTime? @map("held_until")
  createdAt          DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assignedToMemberId])
  @@index([heldByHoldId])
  @@index([heldUntil])
  @@map("customer_signs")
}

model CustomerRider {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  riderId            String    @map("rider_id")
  isOwned            Boolean   @default(true) @map("is_owned")
  inStorage          Boolean   @default(true) @map("in_storage")
  assignedToMemberId String?   @map("assigned_to_member_id")
  heldByHoldId       String?   @map("held_by_hold_id")
  heldUntil          DateTime? @map("held_until")
  createdAt          DateTime  @default(now()) @map("created_at")

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rider RiderCatalog @relation(fields: [riderId], references: [id])

  @@index([assignedToMemberId])
  @@index([heldByHoldId])
  @@index([heldUntil])
  @@map("customer_riders")
}

model CustomerLockbox {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  lockboxTypeId      String    @map("lockbox_type_id")
  serialNumber       String?   @map("serial_number")
  code               String?
  isOwned            Boolean   @default(true) @map("is_owned")
  inStorage          Boolean   @default(true) @map("in_storage")
  assignedToMemberId String?   @map("assigned_to_member_id")
  heldByHoldId       String?   @map("held_by_hold_id")
  heldUntil          DateTime? @map("held_until")
  createdAt          DateTime  @default(now()) @map("created_at")

  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  lockboxType           LockboxType           @relation(fields: [lockboxTypeId], references: [id])
  installationLockboxes InstallationLockbox[]

  @@index([assignedToMemberId])
  @@index([heldByHoldId])
  @@index([heldUntil])
  @@map("customer_lockboxes")
}

model CustomerBrochureBox {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  description        String?
  inStorage          Boolean  @default(true) @map("in_storage")
  assignedToMemberId String?  @map("assigned_to_member_id")
  createdAt          DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assignedToMemberId])
  @@map("customer_brochure_boxes")
}

model CustomerOtherItem {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  description        String
  // Team feature: assigns this item to one of the team's TeamMembers (null = pool).
  assignedToMemberId String?  @map("assigned_to_member_id")
  createdAt          DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assignedToMemberId])
  @@map("customer_other_items")
}

// ============================================
// Orders
// ============================================

model Order {
  id          String  @id @default(cuid())
  orderNumber String  @unique @map("order_number")
  userId      String  @map("user_id")
  postTypeId  String? @map("post_type_id") // Optional - orders can be for other services only

  // Property info
  propertyAddress           String       @map("property_address")
  propertyCity              String       @map("property_city")
  propertyState             String       @default("KY") @map("property_state")
  propertyZip               String       @map("property_zip")
  propertyType              PropertyType @default(residential) @map("property_type")
  propertyNotes             String?      @map("property_notes")
  installationLocationImage String?      @map("installation_location_image") @db.Text

  // Installation details
  isGatedCommunity     Boolean @default(false) @map("is_gated_community")
  gateCode             String? @map("gate_code")
  hasMarkerPlaced      Boolean @default(false) @map("has_marker_placed")
  signOrientation      String? @map("sign_orientation")
  signOrientationOther String? @map("sign_orientation_other")
  installationLocation String? @map("installation_location")

  // Scheduling
  scheduledDate DateTime? @map("scheduled_date")
  isExpedited   Boolean   @default(false) @map("is_expedited")

  // Pricing
  subtotal                  Decimal @db.Decimal(10, 2)
  fuelSurcharge             Decimal @default(2.47) @map("fuel_surcharge") @db.Decimal(10, 2)
  noPostSurcharge           Decimal @default(0) @map("no_post_surcharge") @db.Decimal(10, 2)
  // Out-of-area surcharge: $50 (5000 cents) when ZIP falls in surcharge band of nearest center.
  serviceAreaSurchargeCents Int     @default(0) @map("service_area_surcharge_cents")
  serviceAreaCenterId       String? @map("service_area_center_id")
  // Round 25 audit trail: which drive-time signal decided this order's tier.
  // Values: 'haversine_estimate' | 'zip_cache' | 'address_lookup' | 'address_cache'.
  // Null for exempt orders, override-decided orders, and pre-Round-25 rows.
  serviceAreaDriveMinutes      Int?    @map("service_area_drive_minutes")
  serviceAreaDriveTimeSource   String? @map("service_area_drive_time_source")
  // CR4 (Round 22): true when this order was priced as a flat-fee order (payer
  // had flatFeeBilling at creation). Frozen on the order so edits recompute as
  // flat (no diff-charge) and invoices/reporting can identify clamped orders.
  flatFeeApplied            Boolean @default(false) @map("flat_fee_applied")
  expediteFee               Decimal @default(0) @map("expedite_fee") @db.Decimal(10, 2)
  discount                  Decimal @default(0) @db.Decimal(10, 2)
  tax                       Decimal @default(0) @db.Decimal(10, 2)
  total                     Decimal @db.Decimal(10, 2)

  // Promo Code
  promoCodeId String? @map("promo_code_id")

  // Status
  status          OrderStatus   @default(pending)
  paymentStatus   PaymentStatus @default(pending) @map("payment_status")
  paymentIntentId String?       @map("payment_intent_id")
  paidAt          DateTime?     @map("paid_at")

  // If a team_admin placed this order on behalf of an agent, placedByUserId
  // is the team_admin (charged Stripe customer); userId is still the agent.
  // Null = the agent placed it themselves.
  placedByUserId String? @map("placed_by_user_id")

  // Free-text name of the agent on the team who sold this property. Only
  // captured for team_admin accounts (Peggy & similar) — they manage a team
  // as one user account and label each order with the responsible agent.
  placedForAgentName String? @map("placed_for_agent_name")

  // Refund / cancellation lifecycle (v1: full refund only). All nullable;
  // additive migration. paymentStatus flips to 'refunded' only via the
  // charge.refunded webhook (single source of truth — survives both our
  // explicit refunds.create calls AND Stripe-dashboard-initiated refunds).
  refundId                String?   @unique @map("refund_id")
  refundInitiatedAt       DateTime? @map("refund_initiated_at")
  refundedAt              DateTime? @map("refunded_at")
  refundedAmount          Decimal?  @map("refunded_amount") @db.Decimal(10, 2)
  refundReason            String?   @map("refund_reason")
  refundEmailSentAt       DateTime? @map("refund_email_sent_at")
  // Reservation flag — set via conditional updateMany before sending the
  // order-received email so the synchronous post-charge path (single-order
  // POST + batch POST) and the payment_intent.succeeded webhook can't
  // double-send. Whichever updateMany lands first wins; the other no-ops.
  confirmationEmailSentAt DateTime? @map("confirmation_email_sent_at")
  cancelledAt             DateTime? @map("cancelled_at")
  cancelledByUserId       String?   @map("cancelled_by_user_id")
  cancelReason            String?   @map("cancel_reason")

  // Post-rental billing controls. Override = per-order admin opt-in to bring
  // grandfathered orders onto the schedule. StoppedAt = the moment pickup
  // begins (set when removal is scheduled OR completed) — cron stops here.
  postRentalEnabledOverride Boolean   @default(false) @map("post_rental_enabled_override")
  // CR2 (Round 22): admin manual opt-OUT of recurring post-rental billing for
  // this order — e.g. the agent supplied their own post. Wins over the opt-in
  // override above. Auto-set true at checkout for no-post orders.
  postRentalDisabled        Boolean   @default(false) @map("post_rental_disabled")
  postRentalStoppedAt       DateTime? @map("post_rental_stopped_at")

  // Invoice the order was bundled onto for collection. Null while the order is
  // still pending_invoice. Set when an admin bundles a date range of unpaid
  // orders into an Invoice via /admin/invoices.
  invoiceId String? @map("invoice_id")

  // Edit-time diff charge tracking. Set on every order edit; null only on
  // orders that have never been edited. Drives the admin worklist filter
  // and survives audit-log failures (the audit row is secondary).
  editChargeStatus        EditChargeStatus? @map("edit_charge_status")
  // Free-text error from the most recent failed diff charge (Stripe error
  // message). Only meaningful when editChargeStatus = 'charge_failed' or
  // 'no_payment_method'. Cleared on the next successful charge.
  editChargeLastError     String?           @map("edit_charge_last_error")
  // PaymentIntent id of the most recent successful diff charge. Lets the
  // webhook reconcile metadata.kind='order_edit_diff' events by orderId and
  // gives admin a click-through reference in /admin/orders/[id].
  lastEditPaymentIntentId String?           @map("last_edit_payment_intent_id")
  lastEditChargedAt       DateTime?         @map("last_edit_charged_at")
  // Cumulative negative-diff balance ("we owe customer $X"). Incremented on
  // each credit_pending edit, decremented manually when admin issues the
  // Stripe refund. ALSO netted against the next positive diff at edit time so
  // a customer who lost a $5 rider then later added $10 in services is charged
  // $5 net rather than charged $10 + still owed $5.
  pendingCreditCents      Int               @default(0) @map("pending_credit_cents")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  placedBy          User?              @relation("OrdersPlacedBy", fields: [placedByUserId], references: [id])
  cancelledBy       User?              @relation("OrderCancelledBy", fields: [cancelledByUserId], references: [id])
  postType          PostType?          @relation(fields: [postTypeId], references: [id])
  promoCode         PromoCode?         @relation(fields: [promoCodeId], references: [id])
  orderItems        OrderItem[]
  installation      Installation?
  consumedHolds     InventoryHold[]    @relation("InventoryHoldConsumer")
  postRentalCharges PostRentalCharge[]
  invoice           Invoice?           @relation(fields: [invoiceId], references: [id])

  @@index([placedByUserId])
  @@index([cancelledByUserId])
  @@index([invoiceId])
  // Admin worklist: find orders that need follow-up after a failed/skipped
  // edit-time diff charge.
  @@index([editChargeStatus])
  @@map("orders")
}

// Bundled invoice covering a customer's pending_invoice orders within a date
// range. Created by an admin via /admin/invoices when collecting from accounts
// on monthly/weekly cadence. One Stripe PaymentIntent per invoice — when it
// succeeds, every child Order's paymentStatus flips to `succeeded`.
model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique @map("invoice_number")
  userId        String        @map("user_id")

  // Date range the invoice covers (snapshotted for display + audit).
  rangeStart DateTime @map("range_start")
  rangeEnd   DateTime @map("range_end")

  subtotal Decimal @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  status InvoiceStatus @default(sent)

  sentAt          DateTime? @map("sent_at")
  paidAt          DateTime? @map("paid_at")
  voidedAt        DateTime? @map("voided_at")
  paymentIntentId String?   @unique @map("payment_intent_id")

  // Stripe Payment Link (plink_*) created at bundler-time so the email can
  // link directly to Stripe-hosted payment (customer never lands on
  // pinkposts.com to pay). Payment Links don't expire; auto-deactivate after
  // one successful checkout via restrictions.completed_sessions.limit=1.
  // (Column kept as checkout_session_id for back-compat with the rejected
  // Checkout Session approach — stores the Payment Link id either way.)
  checkoutSessionId String? @map("checkout_session_id")
  checkoutUrl       String? @map("checkout_url")

  // Opaque random token granting public read-only access to this invoice's
  // PDF via /api/invoices/[id]/pdf?token=…. Unguessable so anyone with the
  // emailed link (and only them) can view the PDF without logging in.
  publicPdfToken String? @map("public_pdf_token")

  // Single email-send reservation flag mirroring Order.confirmationEmailSentAt
  // to keep the "send invoice" call idempotent even if a webhook retries it.
  invoiceEmailSentAt DateTime? @map("invoice_email_sent_at")

  // Background-worker email state (Round 21). The POST /api/admin/invoices
  // route returns immediately after the DB transaction and a fire-and-forget
  // worker handles Stripe Payment Link + PDF generation + Resend send. These
  // columns make the worker's progress observable in the admin UI so failures
  // don't disappear into the void.
  emailStatus       InvoiceEmailStatus @default(queued) @map("email_status")
  // The email address the invoice was actually sent to (snapshot). Set at
  // creation time from the recipientEmailOverride OR user.billingEmail OR
  // user.email. The Resend endpoint can atomically overwrite this when the
  // admin retries to a different address. NEVER re-derive at send time —
  // always trust the snapshot to keep the audit log faithful.
  recipientEmail    String?            @map("recipient_email")
  // Last error from the worker (Stripe / PDF / Resend). Cleared on the next
  // successful send. Surfaced inline on the admin invoices page so failures
  // are visible without a tooltip hover.
  emailError        String?            @map("email_error")
  // Timestamp when the worker claimed this row (set when emailStatus flips
  // queued/failed → sending). Used by the startup heal hook to recover rows
  // left in 'sending' by a process restart mid-job.
  sendingStartedAt  DateTime?          @map("sending_started_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders          Order[]
  serviceRequests ServiceRequest[]

  @@index([userId])
  @@index([status])
  // Admin worklist: surface invoices that need retry (failed) or are still
  // queued/sending so the page can poll only the ones actively transitioning.
  @@index([emailStatus])
  @@map("invoices")
}

enum InvoiceStatus {
  sent
  paid
  void
}

// Background-worker outcome of the invoice email send. Distinct from
// InvoiceStatus (which tracks the bundle/paid lifecycle).
enum InvoiceEmailStatus {
  // Row created, worker not yet started.
  queued
  // Worker has claimed the row and is doing Stripe + PDF + Resend.
  // sendingStartedAt tracks WHEN — admin startup heal hook flips rows
  // stuck >10min back to 'failed' so a manual Resend can recover them.
  sending
  // Resend returned a message id; email is on its way.
  sent
  // Worker hit an error somewhere in the pipeline; emailError populated.
  failed
  // shouldSendEmail() returned false (recipient opted out of invoice emails).
  skipped
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String  @map("order_id")
  itemType     String  @map("item_type")
  itemCategory String? @map("item_category") // 'storage', 'rental', 'new', 'owned'
  description  String
  quantity     Int     @default(1)
  unitPrice    Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice   Decimal @map("total_price") @db.Decimal(10, 2)

  // Optional references to customer inventory
  riderId               String? @map("rider_id")
  customerRiderId       String? @map("customer_rider_id")
  customerBrochureBoxId String? @map("customer_brochure_box_id")
  customerLockboxId     String? @map("customer_lockbox_id")
  customerSignId        String? @map("customer_sign_id")
  customValue           String? @map("custom_value")

  createdAt DateTime @default(now()) @map("created_at")

  order Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rider RiderCatalog? @relation(fields: [riderId], references: [id])

  @@map("order_items")
}

enum PropertyType {
  residential
  commercial
  land
  multi_family
  house
  construction
  bare_land
}

enum OrderStatus {
  pending
  confirmed
  scheduled
  in_progress
  completed
  cancelled
}

enum PaymentStatus {
  pending
  processing
  succeeded
  failed
  refunded
  // Order placed by an invoice-billing customer. No Stripe charge happened at
  // placement. Flips to `succeeded` when the parent Invoice's payment intent
  // succeeds (see app/api/webhooks/stripe handler).
  pending_invoice
}

// Outcome of the most recent diff charge attempted at order-edit time.
// Drives the admin worklist filter at /admin/orders and the edit-time
// receipt email's change-summary block. Kept in sync with the discriminated
// union EditChargeOutcome in app/api/orders/[id]/edit/route.ts.
enum EditChargeStatus {
  // Edit saved with no total change (no Stripe interaction).
  no_change
  // Card on file was charged the positive diff successfully. lastEditPaymentIntentId
  // points to the diff PI in Stripe.
  charged_diff
  // Card on file declined / SCA challenge / off_session refused — needs follow-up.
  charge_failed
  // Negative diff: customer owed a refund, awaiting manual Stripe-dashboard refund
  // by admin. pendingCreditCents holds the unresolved amount.
  credit_pending
  // Positive diff but no card on file (and never charged off_session). Admin must
  // collect manually.
  no_payment_method
  // Order is on invoice billing (paymentStatus = 'pending_invoice'); the diff is
  // already reflected in the order.total so it folds into the next bundled invoice.
  invoice_billing_skip
}

// ============================================
// Installations
// ============================================

model Installation {
  id      String @id @default(cuid())
  orderId String @unique @map("order_id")
  userId  String @map("user_id")

  propertyAddress String @map("property_address")
  propertyCity    String @map("property_city")
  propertyState   String @default("KY") @map("property_state")
  propertyZip     String @map("property_zip")

  installedAt DateTime           @default(now()) @map("installed_at")
  status      InstallationStatus @default(active)
  removalDate DateTime?          @map("removal_date")
  removedAt   DateTime?          @map("removed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order           Order                 @relation(fields: [orderId], references: [id])
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  riders          InstallationRider[]
  lockboxes       InstallationLockbox[]
  serviceRequests ServiceRequest[]

  @@map("installations")
}

model InstallationRider {
  id             String    @id @default(cuid())
  installationId String    @map("installation_id")
  riderId        String    @map("rider_id")
  isRental       Boolean   @default(false) @map("is_rental")
  installedAt    DateTime  @default(now()) @map("installed_at")
  removedAt      DateTime? @map("removed_at")

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  rider        RiderCatalog @relation(fields: [riderId], references: [id])

  @@map("installation_riders")
}

model InstallationLockbox {
  id                String    @id @default(cuid())
  installationId    String    @map("installation_id")
  lockboxTypeId     String    @map("lockbox_type_id")
  customerLockboxId String?   @map("customer_lockbox_id")
  isRental          Boolean   @default(false) @map("is_rental")
  code              String?
  installedAt       DateTime  @default(now()) @map("installed_at")
  removedAt         DateTime? @map("removed_at")

  installation    Installation     @relation(fields: [installationId], references: [id], onDelete: Cascade)
  lockboxType     LockboxType      @relation(fields: [lockboxTypeId], references: [id])
  customerLockbox CustomerLockbox? @relation(fields: [customerLockboxId], references: [id], onDelete: SetNull)

  @@index([customerLockboxId])
  @@map("installation_lockboxes")
}

enum InstallationStatus {
  active
  removal_scheduled
  removed
}

// ============================================
// Service Requests
// ============================================

model ServiceRequest {
  id                     String               @id @default(cuid())
  installationId         String?              @map("installation_id")
  userId                 String               @map("user_id")
  type                   ServiceRequestType
  status                 ServiceRequestStatus @default(pending)
  description            String?
  requestedDate          DateTime?            @map("requested_date")
  notes                  String?
  adminNotes             String?              @map("admin_notes")
  completedAt            DateTime?            @map("completed_at")
  // Invoicing — service trips aren't always a flat $40, so admin can bill a
  // variable amount and charge the customer's saved default card.
  invoiceAmount          Decimal?             @map("invoice_amount") @db.Decimal(10, 2)
  invoiceStatus          String?              @map("invoice_status") // 'paid' | 'failed' | 'pending_invoice'
  invoicePaymentIntentId String?              @map("invoice_payment_intent_id")
  invoicePaidAt          DateTime?            @map("invoice_paid_at")
  // Bundled-invoice FK — populated when an admin rolls a completed SR onto
  // a multi-item Invoice for invoice-billing customers (mirrors Order.invoiceId).
  invoiceId              String?              @map("invoice_id")
  // Unlisted-address fields — populated when a service trip is requested for
  // an address Pink Posts hasn't installed at (no Installation row exists).
  unlistedAddress        String?              @map("unlisted_address")
  unlistedCity           String?              @map("unlisted_city")
  unlistedState          String?              @map("unlisted_state")
  unlistedZip            String?              @map("unlisted_zip")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  installation Installation? @relation(fields: [installationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@map("service_requests")
}

enum ServiceRequestType {
  removal
  service
  repair
  replacement
}

enum ServiceRequestStatus {
  pending
  acknowledged
  scheduled
  in_progress
  completed
  cancelled
}

