enum DiscountType {
  percentage
  fixed
}

// ============================================
// Inventory Holds (soft-reservation for cart)
// ============================================
// When a team_admin or customer adds a specific physical inventory item to
// their cart, an InventoryHold row reserves it for 15 minutes so concurrent
// adders (other team members, the same user in another tab) can't double-
// claim it before checkout. Holds are released on explicit cart-remove,
// extended by a heartbeat, swept on TTL expiry, and consumed at checkout.
//
// The polymorphic (itemType, itemId) target points at one of CustomerSign /
// CustomerRider / CustomerLockbox — brochure boxes are intentionally
// excluded (they're quantity-aggregated, not picked per-row).
//
// Correctness:
//   - Partial unique index on (itemType, itemId) WHERE consumedByOrderId IS
//     NULL AND releasedAt IS NULL prevents two live holds per item at the
//     DB level. Added via raw SQL after `prisma db push` (Prisma can't
//     express the WHERE clause natively).
//   - Each Customer* row also carries denormalized heldByHoldId + heldUntil
//     so visibility queries and conditional-UPDATE claims don't have to
//     join. The bump operation MUST update both columns atomically — see
//     lib/inventory-holds.ts for the invariant.

enum HoldItemType {
  sign
  rider
  lockbox
}

model InventoryHold {
  id                         String       @id @default(cuid())
  itemType                   HoldItemType @map("item_type")
  itemId                     String       @map("item_id")
  // The user who "owns" the cart (charged Stripe customer / cart owner).
  ownerUserId                String       @map("owner_user_id")
  // The user who clicked. Usually = ownerUserId, except when admin or
  // team_admin acts on behalf of a customer.
  actorUserId                String       @map("actor_user_id")
  // When admin/team_admin acts for a customer, this is that customer.
  onBehalfOfUserId           String?      @map("on_behalf_of_user_id")
  // The TeamMember (agent) this item is/was assigned to, snapshotted at
  // hold creation. Lets us refuse mid-cart reassignment without a join.
  assignedToMemberIdSnapshot String?      @map("assigned_to_member_id_snapshot")
  // localStorage uuid today; swaps to server Cart.id when track #4 lands.
  cartSessionId              String?      @map("cart_session_id")
  // The CartItem-level id (one cart entry that this hold belongs to), so
  // removeItem() can release precisely without scanning the whole cart.
  cartItemId                 String?      @map("cart_item_id")
  // Server-computed expiry. Use Postgres NOW() + interval, never Node.now,
  // to avoid clock skew. See acquireHold helper.
  expiresAt                  DateTime     @map("expires_at")
  // Set when claimed at checkout; sweeper reaps these on next pass.
  consumedByOrderId          String?      @map("consumed_by_order_id")
  // Set on explicit release (cart remove / clearCart); sweeper reaps.
  releasedAt                 DateTime?    @map("released_at")
  createdAt                  DateTime     @default(now()) @map("created_at")

  owner           User   @relation("InventoryHoldOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  actor           User   @relation("InventoryHoldActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  onBehalfOf      User?  @relation("InventoryHoldOnBehalfOf", fields: [onBehalfOfUserId], references: [id], onDelete: Cascade)
  consumedByOrder Order? @relation("InventoryHoldConsumer", fields: [consumedByOrderId], references: [id], onDelete: SetNull)

  @@index([itemType, itemId])
  @@index([ownerUserId, expiresAt])
  @@index([cartItemId])
  @@index([cartSessionId])
  @@index([expiresAt])
  @@index([consumedByOrderId])
  @@index([releasedAt])
  @@map("inventory_holds")
}

// ============================================
// Audit Log
// ============================================
// Append-only record of consequential actions (refunds, cancellations,
// role changes, inventory reassignments, etc.). Never updated, never deleted.
// actorEmail/actorRole are denormalized so the record survives user deletion.

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  actorUserId String? @map("actor_user_id")
  actorEmail  String? @map("actor_email")
  actorRole   String? @map("actor_role")

  action     String
  targetType String? @map("target_type")
  targetId   String? @map("target_id")

  metadata  Json?
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// Service Centers (drive-time gating)
// ============================================
// Each row defines one shop with two drive-time bands. ZIP requests are gated
// by computing minutes from the ZIP centroid to each active center; the BEST
// tier across centers wins (Standard > Surcharge > Out-of-area). Admin-editable
// so Ryan can tune bands without a redeploy.

model ServiceCenter {
  id               String   @id @default(cuid())
  name             String   @unique
  addressLine      String?  @map("address_line")
  city             String
  state            String   @db.VarChar(2)
  zip              String   @db.VarChar(5)
  // Geocoded once at create time — used by haversine to ZIP centroid.
  lat              Decimal  @db.Decimal(9, 6)
  lng              Decimal  @db.Decimal(9, 6)
  // Upper bound of standard band in minutes (<= = standard tier).
  standardMinutes  Int      @map("standard_minutes")
  // Upper bound of surcharge band in minutes (> = out_of_area tier).
  surchargeMinutes Int      @map("surcharge_minutes")
  surchargeCents   Int      @default(5000) @map("surcharge_cents")
  contactPhone     String   @default("859-395-8188") @map("contact_phone")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("service_centers")
}

// Explicit per-ZIP service-area overrides (CR1 / Round 22). The straight-line
// haversine distance model under-predicts drive time for some rural corridors
// (e.g. Danville 40422 estimates ~34 min but is a ~53 min real drive), so those
// ZIPs never trip the surcharge band. resolveServiceArea() consults this list
// AFTER the exempt fast-path but BEFORE the distance model, so a listed ZIP is
// authoritative. tier is one of 'surcharge' | 'out_of_area' | 'standard'.
model ServiceAreaZipOverride {
  zip            String   @id @db.VarChar(5)
  tier           String   @default("surcharge")
  surchargeCents Int      @default(5000) @map("surcharge_cents")
  note           String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("service_area_zip_overrides")
}

// Drive-time cache (Round 25). Replaces the silent-undercharge problem where
// haversine × road-factor estimates were systematically low for back-road
// ZIPs (Berea, Danville). Two layers:
//
// 1. ZipDriveTimeCache — one row per (zip, centerId). Seeded in bulk via
//    scripts/seed-zip-drive-times.ts using Google Routes API; used by the
//    cart-preview quote endpoint and as the first pass at order POST time.
// 2. AddressDriveTimeCache — one row per (addressHash, centerId). Populated
//    on-demand at order POST time when the ZIP estimate lands within
//    BORDERLINE_WINDOW minutes of either threshold (per Ryan: <35 = trust
//    ZIP; otherwise ±15 of standardMinutes or surchargeMinutes = upgrade).
//
// Both rows are subject to Google Maps Platform Service Terms: drive-time
// values must be refreshed every 30 days. Resolver and seed script both
// treat cachedAt + 30 days as the freshness boundary.
model ZipDriveTimeCache {
  zip          String   @db.VarChar(5)
  centerId     String   @map("center_id")
  driveMinutes Int      @map("drive_minutes")
  source       String   @default("google_routes")
  cachedAt     DateTime @default(now()) @map("cached_at")

  @@id([zip, centerId])
  @@index([cachedAt])
  @@map("zip_drive_time_cache")
}

model AddressDriveTimeCache {
  addressHash  String   @db.VarChar(64) @map("address_hash")
  centerId     String   @map("center_id")
  address      String
  driveMinutes Int      @map("drive_minutes")
  source       String   @default("google_routes")
  cachedAt     DateTime @default(now()) @map("cached_at")

  @@id([addressHash, centerId])
  @@index([cachedAt])
  @@map("address_drive_time_cache")
}

// ============================================
// Post-Rental Billing
// ============================================
// Tracks every scheduled / attempted / settled post-rental fee. One row per
// (orderId, periodStart) — unique constraint protects against concurrent cron
// runs and same-day re-runs double-charging. The cron writes rows in Pass 1
// (scheduling) and updates them in Pass 2 (attempting). Status state machine:
// scheduled -> attempting -> succeeded | failed | skipped. The unique index
// on (orderId, periodStart) is the source of truth for "did we already
// schedule this period" — no auxiliary state needed.

model PostRentalCharge {
  id                    String                 @id @default(cuid())
  orderId               String                 @map("order_id")
  order                 Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  chargeType            PostRentalChargeType
  amountCents           Int                    @map("amount_cents")
  periodStart           DateTime               @map("period_start")
  periodEnd             DateTime               @map("period_end")
  stripePaymentIntentId String?                @map("stripe_payment_intent_id")
  status                PostRentalChargeStatus @default(scheduled)
  attemptedAt           DateTime?              @map("attempted_at")
  succeededAt           DateTime?              @map("succeeded_at")
  failureCode           String?                @map("failure_code")
  failureMessage        String?                @map("failure_message")
  attemptCount          Int                    @default(0) @map("attempt_count")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  @@unique([orderId, periodStart], name: "post_rental_charge_order_period_unique")
  @@index([status, periodStart])
  @@index([orderId])
  @@map("post_rental_charges")
}

enum PostRentalChargeType {
  six_month  @map("6mo")
  nine_month @map("9mo")
  monthly
}

enum PostRentalChargeStatus {
  scheduled
  attempting
  succeeded
  failed
  skipped
}

// Per-user notification-preference change log — answers "when did Peggy opt out"
model UserPreferenceChange {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  changedBy String   @map("changed_by") // actor userId (usually == userId; admin override possible)
  changes   Json // { emailOrderConfirmations: { from: true, to: false }, ... }
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_preference_changes")
}
